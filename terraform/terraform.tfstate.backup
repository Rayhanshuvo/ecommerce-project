          "attributes": {
            "binary_data": null,
            "data": {
              "init.sql": "CREATE DATABASE IF NOT EXISTS notification;\r\nCREATE DATABASE IF NOT EXISTS order_db;\r\nCREATE USER IF NOT EXISTS 'app'@'%' IDENTIFIED BY 'app123';\r\nGRANT ALL PRIVILEGES ON notification.* TO 'app'@'%';\r\nGRANT ALL PRIVILEGES ON order_db.* TO 'app'@'%';\r\nFLUSH PRIVILEGES;\r\n"
            },
            "id": "ecommerce/mysql-init",
            "immutable": false,
            "metadata": [
              {
                "annotations": null,
