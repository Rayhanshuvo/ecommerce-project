            "data": {
              "prometheus.yml": "global:\r\n  scrape_interval: 15s\r\nscrape_configs:\r\n  - job_name: 'notification'\r\n    metrics_path: '/actuator/prometheus'\r\n    static_configs:\r\n      - targets: ['notification:8082']\r\n  - job_name: 'order'\r\n    metrics_path: '/actuator/prometheus'\r\n    static_configs:\r\n      - targets: ['order:8083']\r\n"
